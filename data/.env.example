PORT=Your Port Number
JWT_SECRET= 32 character random string (you can generate one at https://randomkeygen.com/)
# Turso remote database (get these from turso.tech after setup)
TURSO_URL=turso database URL
TURSO_TOKEN=turso auth token

# Leave empty to use local SQLite file instead of Turso
# TURSO_URL=
# TURSO_TOKEN=

# Superadmin credentials (used by seed.js)
SUPERADMIN_USERNAME=admin username
SUPERADMIN_PASSWORD=admin password

# Set to true to require an invite code to register
REQUIRE_INVITE=false / true

CORS_ORIGIN= depends on your frontend URL, e.g. http://localhost:5173 for local development, or https://yourdomain.com for production. You can also set it to * to allow all origins (not recommended for production).